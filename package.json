{
  "name": "n8n-nodes-llmgraph",
  "version": "0.1.1",
  "description": "n8n community node for LLMGraph: invoke workflows deployed on llmgraph.ai from your n8n workflows",
  "license": "MIT",
  "homepage": "https://github.com/abahocodes/n8n-nodes-llmgraph",
  "bugs": {
    "url": "https://github.com/abahocodes/n8n-nodes-llmgraph/issues"
  },
  "keywords": [
    "n8n-community-node-package",
    "llmgraph",
    "llm",
    "ai",
    "workflow"
  ],
  "author": {
    "name": "Katabarwa Labs Inc.",
    "email": "founders@llmgraph.ai"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abahocodes/n8n-nodes-llmgraph.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/LlmGraphApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/LlmGraph/LlmGraph.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "eslint": "9.32.0",
    "prettier": "3.6.2",
    "release-it": "^19.0.4",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "publishConfig": {
    "access": "public"
  }
}
